  "item": [
    {
      "name": "Create a User",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// 1. Chai Assertion: Check if the status code is exactly 201\r",
              "pm.test(\"Verify Status Code is 201 Created\", function () {\r",
              "    pm.response.to.have.status(201);\r",
              "});\r",
              "\r",
              "// 2. Extraction: Read the JSON response body that the server sent us\r",
              "var responseData = pm.response.json();\r",
              "\r",
              "// 3. API Chaining: Grab the \"token\" value from the JSON and save it as an Environment Variable\r",
              "pm.environment.set(\"token\", responseData.token);\r",
              "\r",
              "console.log(\"Token saved successfully: \" + responseData.token);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\r\n    \"firstName\": \"Test\",\r\n    \"lastName\": \"User\",\r\n    \"email\": \"postman_{{$timestamp}}@fake.com\",\r\n    \"password\": \"myPassword\"\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "https://thinking-tester-contact-list.herokuapp.com/users",
          "protocol": "https",
          "host": [
            "thinking-tester-contact-list",
            "herokuapp",
            "com"
          ],
          "path": [
            "users"
          ]
        }
